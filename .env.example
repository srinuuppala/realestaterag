# ─────────────────────────────────────────────────────────────────────────────
#  LLM — Groq by default: free, no credit card, OpenAI-compatible.
#  Get a key in 60 seconds at https://console.groq.com  → API Keys
# ─────────────────────────────────────────────────────────────────────────────
GROQ_API_KEY=
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile

# Groq free-tier models (pick one for LLM_MODEL):
#   llama-3.3-70b-versatile   best quality      ~1,000 requests/day   ← default
#   llama-3.1-8b-instant      fastest, highest volume  ~14,400 requests/day
#
# Leave GROQ_API_KEY blank to run in EXTRACTIVE MODE: login, retrieval,
# citations and the refusal path all still work, and the assistant returns the
# retrieved source passages instead of a generated summary.
#
# Any other OpenAI-compatible provider works by changing two lines:
#   OpenAI        LLM_BASE_URL=https://api.openai.com/v1    LLM_MODEL=gpt-4o-mini
#   Local Ollama  LLM_BASE_URL=http://localhost:11434/v1    LLM_MODEL=llama3.1
# (OPENAI_API_KEY / OPENAI_BASE_URL are still honoured as fallbacks.)

TEMPERATURE=0.0
MAX_TOKENS=800
REQUEST_TIMEOUT=60
# Groq's free tier is 30 requests/minute. A 429 is retried with exponential
# backoff rather than failing the user's question.
MAX_RETRIES=3

# ─────────────────────────────────────────────────────────────────────────────
#  Retrieval — runs locally, costs nothing, needs no key
# ─────────────────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
CHUNK_SIZE=900
CHUNK_OVERLAP=150
TOP_K=5
FETCH_K=20
# The semantic floor: chunks further than this (L2 distance on normalised
# vectors, so cosine >= 0.22) are treated as irrelevant. This is what makes an
# honest "I don't know" possible.
MAX_DISTANCE=1.25
DENSE_WEIGHT=0.6

# ─────────────────────────────────────────────────────────────────────────────
#  Conversation
# ─────────────────────────────────────────────────────────────────────────────
MEMORY_WINDOW=6

# ─────────────────────────────────────────────────────────────────────────────
#  Auth — change these before any real deployment
# ─────────────────────────────────────────────────────────────────────────────
AUTH_USERNAME=demo
AUTH_PASSWORD=realestate2026

# ─────────────────────────────────────────────────────────────────────────────
#  Paths / logging
# ─────────────────────────────────────────────────────────────────────────────
KNOWLEDGE_BASE_DIR=data/knowledge_base
INDEX_DIR=data/faiss_index
LOG_LEVEL=INFO
